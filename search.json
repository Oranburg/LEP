---
layout: null
---
[
  {% assign all_pages = site.pages | concat: site.posts %}
  {% for page in all_pages %}
    {% unless page.url contains '/tag/' or page.url == '/search/' or page.url == '/feed.xml' or page.url == '/sitemap.xml' or page.url == '/robots.txt' or page.url == '/offline.html' or page.gated %}
    {
      "title": {{ page.title | default: page.url | jsonify }},
      "url": {{ page.url | relative_url | jsonify }},
      "excerpt": {{ page.excerpt | default: page.description | default: '' | strip_html | strip_newlines | truncate: 300 | jsonify }},
      "content": {{ page.content | strip_html | strip_newlines | truncate: 1000 | jsonify }}
    }{% unless forloop.last %},{% endunless %}
    {% endunless %}
  {% endfor %}
]
