  gem "jekyll-feed"
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
  gem "jekyll-toc"
  gem "jekyll-tagging"
  gem "jekyll-sass-converter", "~> 3.0"
end

gem "webrick", "~> 1.8"
